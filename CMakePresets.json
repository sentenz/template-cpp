{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "displayName": "Base",
      "description": "Common settings for all configurations",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_ARCHIVE_OUTPUT_DIRECTORY": "${sourceDir}/build/${presetName}/lib",
        "CMAKE_LIBRARY_OUTPUT_DIRECTORY": "${sourceDir}/build/${presetName}/lib",
        "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/build/${presetName}/bin",
        "CMAKE_EXPORT_COMPILE_COMMANDS": true,
        "META_PROJECT_NAME": "cpp-concept"
      }
    },
    {
      "name": "debug",
      "displayName": "Configure Debug",
      "description": "Configuration with debug information",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "META_ENABLE_COMPILER_CACHE": true
      },
      "inherits": [
        "base"
      ]
    },
    {
      "name": "release",
      "displayName": "Configure Release",
      "description": "Configuration with release optimization",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "META_ENABLE_COMPILER_CACHE": false
      },
      "inherits": [
        "base"
      ]
    },
    {
      "name": "test",
      "displayName": "Configure Tests (Colocate)",
      "description": "Configuration with colocated tests alongside source files",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "META_BUILD_TESTING_COLOCATE": true,
        "META_ENABLE_COMPILER_CACHE": true
      },
      "inherits": [
        "base"
      ]
    },
    {
      "name": "test-separate",
      "displayName": "Configure Tests (Separate)",
      "description": "Configuration with tests in a separate directory",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "META_BUILD_TESTING_SEPARATE": true,
        "META_ENABLE_COMPILER_CACHE": true
      },
      "inherits": [
        "base"
      ]
    },
    {
      "name": "test-ontarget",
      "displayName": "Configure Tests (On-Target)",
      "description": "Configuration with on-target tests for cross-compiled execution on hardware",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "META_BUILD_TESTING_ONTARGET": true,
        "META_ENABLE_COMPILER_CACHE": true
      },
      "inherits": [
        "base"
      ]
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "displayName": "Build Debug",
      "description": "Build the project with debug information",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "displayName": "Build Release",
      "description": "Build the project with release optimization",
      "configurePreset": "release"
    },
    {
      "name": "test",
      "displayName": "Build Tests (Colocate)",
      "description": "Build the project with colocated tests",
      "configurePreset": "test"
    },
    {
      "name": "test-separate",
      "displayName": "Build Tests (Separate)",
      "description": "Build the project with separate tests",
      "configurePreset": "test-separate"
    },
    {
      "name": "test-ontarget",
      "displayName": "Build Tests (On-Target)",
      "description": "Build the project with on-target tests",
      "configurePreset": "test-ontarget"
    }
  ],
  "testPresets": [
    {
      "name": "test",
      "displayName": "Execute Tests (Colocate)",
      "description": "Execute colocated tests from the build",
      "configuration": "Debug",
      "configurePreset": "test"
    },
    {
      "name": "test-separate",
      "displayName": "Execute Tests (Separate)",
      "description": "Execute separate tests from the build",
      "configuration": "Debug",
      "configurePreset": "test-separate"
    }
  ]
}